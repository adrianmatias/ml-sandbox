+import json
+import os
+
+from datasets import Dataset
+from ragas import EvaluationDataset, evaluate
+from ragas.metrics import (
+    answer_correctness,
+    answer_relevancy,
+    context_precision,
+    context_recall,
+    faithfulness,
+)
+
+from ragblog.conf import CONF
+from ragblog.rag_pipeline import (
+    JSONLoaderConf,
+    RAGChainConf,
+    RagEvaluatorConf,
+    RagPipeline,
+    RagPipelineConf,
+    TextSplitterConf,
+    VectorStoreConf,
+)
+
+# Setup pipeline
+rp_conf = RagPipelineConf(
+    loader=JSONLoaderConf(
+        file_path=os.path.join(CONF.path.data, "blog.jsonl"),
+        jq_schema=".text",
+        text_content=False,
+        json_lines=True,
+    ),
+    splitter=TextSplitterConf(chunk_size=1000, chunk_overlap=10),
+    vectorstore=VectorStoreConf(
+        embedding_model="qwen3-embedding:8b",
+        persist_directory=CONF.path.chroma,
+    ),
+    ragchain=RAGChainConf(prompt_model="rlm/rag-prompt-llama", llm_model="gpt-oss:20b"),
+    evaluator=RagEvaluatorConf(),
+    is_db_ready=False,
+    is_debug=False,
+)
+
+from ragblog.logger_custom import LoggerCustom
+
+pipeline = RagPipeline(conf=rp_conf, logger=LoggerCustom().get_logger())
+
+# Test questions
+questions = [
+    "What is the author's experience with travel?",
+    "Describe the relation between Helena and Alejandra.",
+    "What are the author's thoughts on technology?",
+    "How does the author balance work and personal life?",
+    "What are some key life lessons from the blog?",
+]
+
+# Generate answers and contexts
+data = []
+for question in questions:
+    try:
+        # Get answer
+        answer = pipeline.query(question)
+
+        # Get context (retrieve docs)
+        retriever = pipeline.get_vectorstore().as_retriever(k=10)
+        docs = retriever.invoke(question)
+        context = pipeline.format_docs(docs)
+
+        data.append(
+            {
+                "question": question,
+                "answer": answer,
+                "contexts": [context],
+                "ground_truth": "",
+            }
+        )
+        print(f"Processed: {question[:30]}...")
+    except Exception as e:
+        print(f"Error for question: {question[:30]}... - {e}")
+
+print(f"\nGenerated {len(data)} Q&A pairs")
+
+# Create dataset and evaluate
+try:
+    dataset = Dataset.from_list(data)
+    eval_dataset = EvaluationDataset.from_hf_dataset(dataset)
+
+    result = evaluate(
+        dataset=eval_dataset,
+        metrics=[
+            faithfulness,
+            answer_relevancy,
+            context_recall,
+            context_precision,
+            answer_correctness,
+        ],
+    )
+
+    print("\n=== RAGAS EVALUATION RESULTS ===")
+    print(result)
+
+    # Save results
+    output_path = os.path.join(CONF.path.data, "ragas_evaluation_results.json")
+    with open(output_path, "w") as f:
+        json.dump(result.scores, f, indent=2)
+    print(f"\nResults saved to: {output_path}")
+
+except Exception as e:
+    print(f"RAGAS evaluation failed: {e}")
+
+    # Fallback analysis
+    print("\n=== FALLBACK ANALYSIS ===")
+    for i, item in enumerate(data):
+        print(f"\n{i + 1}. Question: {item['question'][:50]}...")
+        print(f"   Answer length: {len(item['answer'])} chars")
+        print(f"   Context length: {len(item['contexts'][0])} chars")
+        print(f"   Has context: {'Yes' if len(item['contexts'][0]) > 0 else 'No'}")
