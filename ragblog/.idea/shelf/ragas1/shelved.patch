+import json
+import os
+
+from ragblog.conf import CONF
+from ragblog.logger_custom import LoggerCustom
+from ragblog.rag_pipeline import (
+    JSONLoaderConf,
+    RAGChainConf,
+    RagEvaluatorConf,
+    RagPipeline,
+    RagPipelineConf,
+    TextSplitterConf,
+    VectorStoreConf,
+)
+
+
+def run_ragas_evaluation():
+    logger = LoggerCustom().get_logger()
+    logger.info("=== RAGAS EVALUATION START ===")
+
+    rp_conf = RagPipelineConf(
+        loader=JSONLoaderConf(...),  # keep your existing loader config
+        splitter=TextSplitterConf(
+            chunk_size=1000, chunk_overlap=200
+        ),  # increased overlap
+        vectorstore=VectorStoreConf(...),
+        ragchain=RAGChainConf(...),
+        evaluator=RagEvaluatorConf(evaluator_type="ragas"),
+        is_db_ready=False,
+        is_debug=False,
+    )
+
+    pipeline = RagPipeline(conf=rp_conf, logger=logger)
+
+    test_queries = [
+        "What is the author's experience with travel?",
+        "Describe the relation between Helena and Alejandra.",
+        "What are the author's thoughts on technology?",
+        "How does the author balance work and personal life?",
+        "What are some key life lessons from the blog?",
+    ]
+
+    results = []
+    for q in test_queries:
+        logger.info(f"Query: {q}")
+        docs = pipeline.get_retriever(k=8).invoke(q)
+        context = pipeline.format_docs(docs)
+        answer = pipeline.query_with_context(q, context)
+
+        eval_result = pipeline.evaluate_answer(q, answer, context)
+
+        results.append(
+            {
+                "question": q,
+                "answer_preview": answer[:300] + "...",
+                "ragas_scores": eval_result.get("ragas", {}),
+                "insights": eval_result.get("insights", []),
+            }
+        )
+
+    # Save + print summary
+    output_path = os.path.join(CONF.path.data, "ragas_results.json")
+    with open(output_path, "w") as f:
+        json.dump(results, f, indent=2, default=str)
+
+    logger.info("=== RAGAS SUMMARY ===")
+    for r in results:
+        s = r["ragas_scores"]
+        print(
+            f"{q[:60]:60}  CP:{s.get('context_precision', 0):.2f}  CR:{s.get('context_recall', 0):.2f}  F:{s.get('faithfulness', 0):.2f}  AR:{s.get('answer_relevancy', 0):.2f}"
+        )
+        for insight in r["insights"]:
+            print(f"   → {insight}")
+
+    print(f"Full results → {output_path}")
+    print("Next step: if context_recall low → switch to semantic chunking or reranker")
