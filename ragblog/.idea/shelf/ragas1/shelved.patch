+"""RAGAS-based evaluator for modern RAG systems."""
+
+from logging import Logger
+from typing import Any, Dict, List
+
+from datasets import Dataset
+from ragas import EvaluationDataset, evaluate
+from ragas.metrics import (
+    answer_correctness,
+    answer_relevancy,
+    answer_similarity,
+    context_precision,
+    context_recall,
+    faithfulness,
+)
+
+
+class RagasEvaluator:
+    """Modern RAGAS-based evaluator with actionable insights."""
+
+    def __init__(self, judge_model: str = "llama3.1:70b", logger: Logger = None):
+        self.judge_model = judge_model
+        self.logger = logger
+        self.metrics = [
+            faithfulness,
+            answer_relevancy,
+            context_recall,
+            context_precision,
+            answer_correctness,
+            answer_similarity,
+        ]
+
+    def evaluate_dataset(
+        self,
+        questions: List[str],
+        answers: List[str],
+        contexts: List[List[str]],
+        ground_truths: List[str] = None,
+    ) -> Dict[str, Any]:
+        """Evaluate a dataset of Q&A pairs with RAGAS."""
+
+        # Prepare data
+        data = []
+        for i, (q, a, ctx) in enumerate(zip(questions, answers, contexts)):
+            item = {
+                "question": q,
+                "answer": a,
+                "contexts": ctx,
+                "ground_truth": ground_truths[i] if ground_truths else "",
+            }
+            data.append(item)
+
+        # Create dataset
+        dataset = Dataset.from_list(data)
+        eval_dataset = EvaluationDataset.from_hf_dataset(dataset)
+
+        # Evaluate
+        result = evaluate(dataset=eval_dataset, metrics=self.metrics)
+
+        # Add insights
+        insights = self._generate_insights(result)
+
+        return {
+            "scores": result,
+            "insights": insights,
+            "component_analysis": self._analyze_components(result),
+        }
+
+    def _generate_insights(self, result: Dict[str, float]) -> Dict[str, Any]:
+        """Generate actionable insights from scores."""
+        insights = {
+            "overall_score": sum(result.values()) / len(result),
+            "strengths": [],
+            "weaknesses": [],
+            "recommendations": [],
+        }
+
+        # Analyze each metric
+        if result.get("context_precision", 0) < 0.7:
+            insights["weaknesses"].append(
+                "Low context precision - too many irrelevant docs retrieved"
+            )
+            insights["recommendations"].append("Enable reranking or improve embeddings")
+
+        if result.get("context_recall", 0) < 0.7:
+            insights["weaknesses"].append(
+                "Low context recall - missing relevant information"
+            )
+            insights["recommendations"].append("Try hybrid retrieval or larger top-k")
+
+        if result.get("faithfulness", 0) < 0.8:
+            insights["weaknesses"].append("Low faithfulness - hallucinations detected")
+            insights["recommendations"].append(
+                "Improve prompting or use better judge LLM"
+            )
+
+        if result.get("answer_relevancy", 0) < 0.7:
+            insights["weaknesses"].append(
+                "Low answer relevance - answers not addressing questions"
+            )
+            insights["recommendations"].append(
+                "Switch to semantic chunking or query transformation"
+            )
+
+        if result.get("answer_correctness", 0) < 0.7:
+            insights["weaknesses"].append(
+                "Low answer correctness - factual inaccuracies"
+            )
+            insights["recommendations"].append("Use better LLM or add fact-checking")
+
+        # Strengths
+        for metric, score in result.items():
+            if score > 0.8:
+                insights["strengths"].append(f"Strong {metric.replace('_', ' ')}")
+
+        return insights
+
+    def _analyze_components(self, result: Dict[str, float]) -> Dict[str, str]:
+        """Analyze which RAG component is the bottleneck."""
+        analysis = {}
+
+        # Determine primary bottleneck
+        if result.get("context_precision", 0) < result.get("context_recall", 0):
+            analysis["primary_bottleneck"] = "Retrieval precision - too much noise"
+        elif result.get("context_recall", 0) < result.get("context_precision", 0):
+            analysis["primary_bottleneck"] = "Retrieval recall - missing relevant info"
+        elif result.get("faithfulness", 0) < result.get("answer_relevancy", 0):
+            analysis["primary_bottleneck"] = "Generation quality - LLM hallucinations"
+        elif result.get("answer_relevancy", 0) < 0.7:
+            analysis["primary_bottleneck"] = (
+                "Chunking strategy - poor semantic alignment"
+            )
+        else:
+            analysis["primary_bottleneck"] = "Overall system performing well"
+
+        # Component-specific recommendations
+        analysis["retrieval"] = (
+            f"Score: {result.get('context_precision', 0):.2f} precision, {result.get('context_recall', 0):.2f} recall"
+        )
+        analysis["generation"] = (
+            f"Faithfulness: {result.get('faithfulness', 0):.2f}, Correctness: {result.get('answer_correctness', 0):.2f}"
+        )
+        analysis["chunking"] = (
+            f"Relevance: {result.get('answer_relevancy', 0):.2f} (lower suggests chunking issues)"
+        )
+
+        return analysis
